generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  SELLER
  ADMIN
}

model User {
  id       String @id @default(uuid())
  fullName String
  email    String @unique
  password String

  phone               String?
  cooperativeMemberId String?
  memberNumber        String?
  isCooperativeMember Boolean   @default(false)
  cooperativeStatus   String?
  isVerified          Boolean   @default(false)
  otpCode             String?
  otpExpiresAt        DateTime?
  refreshToken        String?

  storeName        String?
  mainCategory     String?
  city             String?
  documentId       String?
  bankAccount      String?
  identityImageUrl String?
  sellerStatus     String? @default("PENDING")
  acceptedTerms    Boolean @default(false)

  role          Role           @default(CUSTOMER)
  isBlocked     Boolean        @default(false)
  products      Product[]
  financings    Financing[]
  notifications Notification[]
  ledgerEntries LedgerEntry[]
  transactions  Transaction[]
  wallet        Wallet?
  orders        Order[]
  loans         Loan[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  buyerConversations  Conversation[] @relation("BuyerConversations")
  sellerConversations Conversation[] @relation("SellerConversations")
  messages            Message[]      @relation("UserMessages")
}

model Product {
  id           String      @id @default(uuid())
  title        String
  description  String
  price        Decimal     @db.Decimal(18, 2)
  stock        Int
  imageUrl     String?
  isFinanced   Boolean     @default(true)
  currency     String      @default("DOP")
  isActive     Boolean     @default(true)
  financings   Financing[]
  orderItems   OrderItem[]
  views        Int         @default(0)
  salesCount   Int         @default(0)
  rankingScore Float       @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  sellerId     String
  seller       User        @relation(fields: [sellerId], references: [id])
  category     String      @default("Otros")
  conversations Conversation[]

  @@index([isActive, category])
  @@index([sellerId, isActive])
  @@index([price])
  @@index([createdAt])
}

model Financing {
  id                String          @id @default(uuid())
  customerId        String
  cedula            String?
  income            Float?
  company           String?
  phone             String?
  address           String?
  productId         String
  totalAmount       Decimal         @db.Decimal(18, 2)
  downPayment       Decimal         @db.Decimal(18, 2)
  remainingDebt     Decimal         @db.Decimal(18, 2)
  months            Int
  monthlyPayment    Decimal         @db.Decimal(18, 2)
  status            FinancingStatus @default(PENDING)
  externalLoanId    String?
  externalStatus    String?
  externalReference String?
  currency          String          @default("DOP")
  exchangeRate      Float?

  requestedAmount         Float?
  requestedMonths         Int?
  requestedMonthlyPayment Float?

  approvedAmount         Float?
  approvedMonths         Int?
  approvedMonthlyPayment Float?

  counterOffer        Json?
  customerAcceptedAt  DateTime?
  sentToCooperativeAt DateTime?
  activatedAt         DateTime?
  cooperativeResponse Json?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  rejectionReason     String?
  createdAt           DateTime      @default(now())
  customer            User          @relation(fields: [customerId], references: [id])
  product             Product       @relation(fields: [productId], references: [id])
  installments        Installment[]
  shipments           Shipment[]

  @@index([customerId, status])
  @@index([productId, status])
  @@index([externalLoanId])
  @@index([externalReference])
}

model Installment {
  id                    String    @id @default(uuid())
  financingId           String
  number                Int
  amount                Float
  dueDate               DateTime
  paid                  Boolean   @default(false)
  paidAt                DateTime?
  externalInstallmentId String?
  externalStatus        String?
  paidAmount            Float?
  createdAt             DateTime  @default(now())
  financing             Financing @relation(fields: [financingId], references: [id])
  status                String    @default("PENDING")
}

enum FinancingStatus {
  PENDING
  SENT_TO_COOPERATIVE
  UNDER_REVIEW
  APPROVED_BY_COOPERATIVE
  COUNTER_OFFER
  CUSTOMER_ACCEPTED
  WAITING_COOPERATIVE_PAYMENT
  ACTIVE
  REJECTED
  COMPLETED
  LATE
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model LedgerEntry {
  id          String     @id @default(uuid())
  userId      String
  type        LedgerType
  amount      Float
  currency    String     @default("DOP")
  reference   String
  description String
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id])
}

enum LedgerType {
  CREDIT
  DEBIT
}

model Transaction {
  id                String            @id @default(uuid())
  userId            String
  amount            Float
  type              TransactionType
  status            TransactionStatus
  currency          String            @default("DOP")
  reference         String?
  description       String?
  createdAt         DateTime          @default(now())
  idempotencyKey    String?           @unique
  providerReference String?
  user              User              @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([reference])
  @@index([providerReference])
}

enum TransactionType {
  PAYMENT
  REFUND
  WITHDRAW
  DEPOSIT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  balance       Decimal  @default(0) @db.Decimal(18, 2)
  frozenBalance Decimal  @default(0) @db.Decimal(18, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}

model Order {
  id                  String      @id @default(uuid())
  customerId          String
  totalAmount         Decimal     @db.Decimal(18, 2)
  currency            String      @default("DOP")
  externalPaymentId   String?
  externalReference   String?
  externalStatus      String?
  cooperativeResponse Json?
  status              OrderStatus @default(PENDING)
  createdAt           DateTime    @default(now())
  customer            User        @relation(fields: [customerId], references: [id])
  items               OrderItem[]
  shipments           Shipment[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  COMPLETED
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  entity      String
  entityId    String
  description String
  metadata    Json?
  ip          String?
  createdAt   DateTime @default(now())
}

model FraudAlert {
  id        String    @id @default(uuid())
  userId    String
  reason    String
  riskLevel RiskLevel
  resolved  Boolean   @default(false)
  createdAt DateTime  @default(now())
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model Loan {
  id     String @id @default(uuid())
  userId String

  amount             Float
  months             Int
  annualInterestRate Float

  monthlyPayment Float
  totalPayment   Float
  totalInterest  Float

  income     Float
  company    String
  documentId String

  score               Int
  status              String    @default("PENDING")
  externalLoanId      String?
  externalStatus      String?
  externalReference   String?
  cooperativeResponse Json?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  rejectionReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([externalLoanId])
  @@index([externalReference])
}

model Shipment {
  id              String         @id @default(uuid())
  orderId         String
  sellerId        String
  customerId      String
  financingId     String?
  status          ShipmentStatus @default(PENDING_PREPARATION)
  trackingNumber  String?
  shippingAddress String?
  province        String?
  city            String?
  sector          String?
  reference       String?
  phone           String?
  notes           String?
  preparedAt      DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  currentLatitude  Float?
  currentLongitude Float?

  trackingStartedAt DateTime?
  trackingEndedAt   DateTime?

  lastLocationAt DateTime?

  isTracking Boolean @default(false)

  order     Order      @relation(fields: [orderId], references: [id])
  financing Financing? @relation(fields: [financingId], references: [id])

  @@index([orderId])
  @@index([sellerId, status])
  @@index([customerId, status])
  @@index([financingId])
}

enum ShipmentStatus {
  PENDING_PREPARATION
  PREPARING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  FAILED
}

model Conversation {
  id        String   @id @default(uuid())

  buyerId   String
  sellerId  String
  productId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer   User @relation("BuyerConversations", fields: [buyerId], references: [id])
  seller  User @relation("SellerConversations", fields: [sellerId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  messages Message[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([productId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String

  content String
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation("UserMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}
